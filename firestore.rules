rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reviews
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - rating: number (required, 1-5)
    //   - message: string (required, 1-1000 chars)
    //   - createdAt: timestamp (required)
    //   - uid: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['name', 'rating', 'message', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.message is string && data.message.size() >= 1 && data.message.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    match /reviews/{reviewId} {
      // Allow anyone to read reviews
      allow read: if true;
      
      // Allow anyone to create a review (publicly accessible for now)
      allow create: if isValidReview(request.resource.data);
      
      // Only owner or admin can update/delete
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
    }

    // Admin check
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "ayansayyad010@gmail.com" && request.auth.token.email_verified == true);
    }
  }
}
